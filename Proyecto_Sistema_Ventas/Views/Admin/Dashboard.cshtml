@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — Botaniq Bake</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Jost', sans-serif;
            background: #faf6f1;
            color: #2a1f17;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: #2a1f17;
            color: white;
            padding: 40px 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .sidebar-brand {
            text-align: center;
            padding: 0 20px 40px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-brand h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 24px;
            font-weight: 300;
            letter-spacing: 3px;
        }

        .sidebar-brand span {
            font-size: 9px;
            letter-spacing: 4px;
            color: #b89a6a;
            text-transform: uppercase;
        }

        .sidebar-menu { padding: 30px 0; flex: 1; }

        .menu-item {
            display: block;
            padding: 14px 30px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: 0.3s;
            border-left: 3px solid transparent;
        }

        .menu-item:hover, .menu-item.active {
            color: white;
            background: rgba(184,154,106,0.15);
            border-left-color: #b89a6a;
        }

        .menu-label {
            padding: 20px 30px 8px;
            font-size: 9px;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
        }

        .sidebar-footer {
            padding: 20px 30px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .logout {
            font-size: 10px;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            text-decoration: none;
            transition: 0.3s;
        }

        .logout:hover { color: #b89a6a; }

        .main { margin-left: 240px; flex: 1; padding: 40px; }

        .page-header {
            margin-bottom: 36px;
        }

        .page-header h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 2px;
        }

        .page-header p {
            font-size: 12px;
            color: #7a6858;
            margin-top: 4px;
            letter-spacing: 1px;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .card {
            background: white;
            border: 1px solid #f2ead8;
            padding: 28px;
            box-shadow: 0 4px 20px rgba(42,31,23,0.05);
        }

        .card-label {
            font-size: 9px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #b89a6a;
            margin-bottom: 12px;
        }

        .card-value {
            font-family: 'Cormorant Garamond', serif;
            font-size: 36px;
            font-weight: 300;
            color: #2a1f17;
            line-height: 1;
        }

        .card-value span { font-size: 18px; }

        .card-sub {
            font-size: 11px;
            color: #7a6858;
            margin-top: 8px;
        }

        .sections {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 24px;
        }

        .section {
            background: white;
            border: 1px solid #f2ead8;
            padding: 28px;
            box-shadow: 0 4px 20px rgba(42,31,23,0.05);
        }

        .section-full {
            background: white;
            border: 1px solid #f2ead8;
            padding: 28px;
            margin-bottom: 24px;
            box-shadow: 0 4px 20px rgba(42,31,23,0.05);
        }

        .section-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 18px;
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #f2ead8;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            text-align: left;
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #b89a6a;
            padding: 10px 12px;
            border-bottom: 1px solid #f2ead8;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #faf6f1;
            color: #2a1f17;
        }

        tr:last-child td { border-bottom: none; }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            font-size: 9px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            border-radius: 20px;
        }

        .badge-pendiente { background: #fef3cd; color: #856404; }
        .badge-preparacion { background: #cfe2ff; color: #084298; }
        .badge-listo { background: #e2d9f3; color: #432874; }
        .badge-entregado { background: #d1e7dd; color: #0a5236; }
        .badge-delivery { background: #f8d7da; color: #842029; }
        .badge-retiro { background: #d1e7dd; color: #0a5236; }

        .stars { color: #b89a6a; font-size: 12px; }

        .empty {
            text-align: center;
            color: #7a6858;
            padding: 24px;
            font-size: 13px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <h1>Botaniq</h1>
            <span>Admin Panel</span>
        </div>
        <nav class="sidebar-menu">
            <div class="menu-label">Principal</div>
            <a href="/Admin/Dashboard" class="menu-item active">Dashboard</a>
            <div class="menu-label">Gestión</div>
            <a href="/Admin/Productos" class="menu-item">Productos</a>
            <a href="/Admin/Usuarios" class="menu-item">Usuarios</a>
            <a href="/Admin/Pedidos" class="menu-item">Pedidos</a>
            <a href="/Admin/Facturas" class="menu-item">Facturas</a>
            <a href="/Admin/Comentarios" class="menu-item">Comentarios</a>
        </nav>
        <div class="sidebar-footer">
            <a href="/Account/Login" class="logout">Cerrar sesión</a>
        </div>
    </aside>

    <main class="main">
        <div class="page-header">
            <h2>Dashboard</h2>
            <p>Bienvenido al panel de administración de Botaniq Bake</p>
        </div>

        <div class="cards">
            <div class="card">
                <div class="card-label">Ventas del mes</div>
                <div class="card-value"><span>$U</span> 0</div>
                <div class="card-sub">Total acumulado</div>
            </div>
            <div class="card">
                <div class="card-label">Pedidos pendientes</div>
                <div class="card-value">0</div>
                <div class="card-sub">Por procesar</div>
            </div>
            <div class="card">
                <div class="card-label">Clientes registrados</div>
                <div class="card-value">0</div>
                <div class="card-sub">Cuentas activas</div>
            </div>
            <div class="card">
                <div class="card-label">Productos</div>
                <div class="card-value">0</div>
                <div class="card-sub">En catálogo</div>
            </div>
            <div class="card">
                <div class="card-label">Stock bajo</div>
                <div class="card-value">0</div>
                <div class="card-sub">Productos con poco stock</div>
            </div>
        </div>

        <div class="section-full">
            <div class="section-title">Últimos Pedidos</div>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Fecha Entrega</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="empty">No hay pedidos aún</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="sections">
            <div class="section">
                <div class="section-title">Últimas Reseñas</div>
                <table>
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Comentario</th>
                            <th>Calificación</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="3" class="empty">No hay reseñas aún</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="section">
                <div class="section-title">Últimas Facturas</div>
                <table>
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Cliente</th>
                            <th>Total</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="4" class="empty">No hay facturas aún</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

</body>
</html>