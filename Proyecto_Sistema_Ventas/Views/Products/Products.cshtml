@{
    ViewData["Title"] = "Productos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos — Botaniq Bake</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Jost', sans-serif;
            background: #faf6f1;
            color: #2a1f17;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: #2a1f17;
            color: white;
            padding: 40px 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .sidebar-brand {
            text-align: center;
            padding: 0 20px 40px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-brand h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 24px;
            font-weight: 300;
            letter-spacing: 3px;
        }

        .sidebar-brand span {
            font-size: 9px;
            letter-spacing: 4px;
            color: #b89a6a;
            text-transform: uppercase;
        }

        .sidebar-menu { padding: 30px 0; flex: 1; }

        .menu-item {
            display: block;
            padding: 14px 30px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: 0.3s;
            border-left: 3px solid transparent;
        }

        .menu-item:hover, .menu-item.active {
            color: white;
            background: rgba(184,154,106,0.15);
            border-left-color: #b89a6a;
        }

        .menu-label {
            padding: 20px 30px 8px;
            font-size: 9px;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
        }

        .sidebar-footer {
            padding: 20px 30px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .logout {
            font-size: 10px;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            text-decoration: none;
            transition: 0.3s;
        }

        .logout:hover { color: #b89a6a; }

        .main { margin-left: 240px; flex: 1; padding: 40px; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 36px;
        }

        .page-header h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 2px;
        }

        .page-header p {
            font-size: 12px;
            color: #7a6858;
            margin-top: 4px;
            letter-spacing: 1px;
        }

        .btn {
            padding: 12px 24px;
            font-family: 'Jost', sans-serif;
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary { background: #2a1f17; color: white; }
        .btn-primary:hover { background: #b89a6a; }

        .btn-edit {
            background: transparent;
            border: 1px solid #b89a6a;
            color: #b89a6a;
            padding: 6px 14px;
            font-size: 9px;
        }

        .btn-edit:hover { background: #b89a6a; color: white; }

        .btn-delete {
            background: transparent;
            border: 1px solid #c0392b;
            color: #c0392b;
            padding: 6px 14px;
            font-size: 9px;
        }

        .btn-delete:hover { background: #c0392b; color: white; }

        .section {
            background: white;
            border: 1px solid #f2ead8;
            padding: 28px;
            box-shadow: 0 4px 20px rgba(42,31,23,0.05);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            text-align: left;
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #b89a6a;
            padding: 10px 12px;
            border-bottom: 1px solid #f2ead8;
        }

        td {
            padding: 14px 12px;
            border-bottom: 1px solid #faf6f1;
            color: #2a1f17;
            vertical-align: middle;
        }

        tr:last-child td { border-bottom: none; }

        td img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 4px;
        }

        .acciones { display: flex; gap: 8px; }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            font-size: 9px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            border-radius: 20px;
        }

        .badge-si { background: #d1e7dd; color: #0a5236; }
        .badge-no { background: #f8d7da; color: #842029; }
        .badge-stock-ok { background: #d1e7dd; color: #0a5236; }
        .badge-stock-bajo { background: #fef3cd; color: #856404; }
        .badge-stock-cero { background: #f8d7da; color: #842029; }

        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(42,31,23,0.5);
            z-index: 100;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.active { display: flex; }

        .modal {
            background: white;
            padding: 40px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 20px 60px rgba(42,31,23,0.2);
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 22px;
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 1px solid #f2ead8;
        }

        label {
            display: block;
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #7a6858;
            margin-bottom: 6px;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #f2ead8;
            background: #faf6f1;
            font-family: 'Jost', sans-serif;
            font-size: 13px;
            color: #2a1f17;
            outline: none;
            margin-bottom: 16px;
            transition: 0.3s;
        }

        input:focus, select:focus, textarea:focus {
            border-color: #b89a6a;
            background: white;
        }

        .check-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }

        .check-row input {
            width: auto;
            margin-bottom: 0;
        }

        .check-row label {
            margin-bottom: 0;
            font-size: 12px;
        }

        .modal-actions {
            display: flex;
            gap: 12px;
            margin-top: 8px;
        }

        .btn-cancel {
            background: transparent;
            border: 1px solid #f2ead8;
            color: #7a6858;
        }

        .btn-cancel:hover { border-color: #2a1f17; color: #2a1f17; }

        .empty {
            text-align: center;
            color: #7a6858;
            padding: 32px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <h1>Botaniq</h1>
            <span>Admin Panel</span>
        </div>
        <nav class="sidebar-menu">
            <div class="menu-label">Principal</div>
            <a href="/Admin/Dashboard" class="menu-item">Dashboard</a>
            <div class="menu-label">Gestión</div>
            <a href="/Admin/Productos" class="menu-item active">Productos</a>
            <a href="/Admin/Usuarios" class="menu-item">Usuarios</a>
            <a href="/Admin/Pedidos" class="menu-item">Pedidos</a>
            <a href="/Admin/Facturas" class="menu-item">Facturas</a>
            <a href="/Admin/Comentarios" class="menu-item">Comentarios</a>
        </nav>
        <div class="sidebar-footer">
            <a href="/Account/Login" class="logout">Cerrar sesión</a>
        </div>
    </aside>

    <main class="main">
        <div class="page-header">
            <div>
                <h2>Productos</h2>
                <p>Gestión del catálogo de Botaniq Bake</p>
            </div>
            <button class="btn btn-primary" onclick="abrirModal()">+ Agregar Producto</button>
        </div>

        <div class="section">
            <table>
                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Personalizable</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="7" class="empty">No hay productos registrados</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

    <!-- MODAL AGREGAR PRODUCTO -->
    <div class="modal-overlay" id="modalProducto">
        <div class="modal">
            <h3>Agregar Producto</h3>

            <label>Nombre</label>
            <input type="text" placeholder="Ej: Torta de Chocolate" />

            <label>Descripción</label>
            <textarea rows="3" placeholder="Descripción del producto..."></textarea>

            <label>Precio ($U)</label>
            <input type="number" placeholder="0.00" />

            <label>Stock</label>
            <input type="number" placeholder="0" min="0" />

            <label>Categoría</label>
            <select>
                <option>Tortas</option>
                <option>Cookies</option>
                <option>Pies</option>
                <option>Tartas</option>
                <option>Cupcakes</option>
                <option>Alfajores</option>
                <option>Salado</option>
                <option>Petit Fours</option>
            </select>

            <label>Imagen</label>
            <input type="file" accept="image/*" />

            <div class="check-row">
                <input type="checkbox" id="personalizable" />
                <label for="personalizable">Producto personalizable</label>
            </div>

            <div class="modal-actions">
                <button class="btn btn-primary">Guardar</button>
                <button class="btn btn-cancel" onclick="cerrarModal()">Cancelar</button>
            </div>
        </div>
    </div>

    <script>
        function abrirModal() {
            document.getElementById('modalProducto').classList.add('active');
        }
        function cerrarModal() {
            document.getElementById('modalProducto').classList.remove('active');
        }
    </script>

</body>
</html>