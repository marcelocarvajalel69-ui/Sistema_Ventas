@{
    ViewData["Title"] = "Facturas";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Facturas — Botaniq Bake</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Jost', sans-serif;
            background: #faf6f1;
            color: #2a1f17;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: #2a1f17;
            color: white;
            padding: 40px 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .sidebar-brand {
            text-align: center;
            padding: 0 20px 40px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-brand h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 24px;
            font-weight: 300;
            letter-spacing: 3px;
        }

        .sidebar-brand span {
            font-size: 9px;
            letter-spacing: 4px;
            color: #b89a6a;
            text-transform: uppercase;
        }

        .sidebar-menu { padding: 30px 0; flex: 1; }

        .menu-item {
            display: block;
            padding: 14px 30px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: 0.3s;
            border-left: 3px solid transparent;
        }

        .menu-item:hover, .menu-item.active {
            color: white;
            background: rgba(184,154,106,0.15);
            border-left-color: #b89a6a;
        }

        .menu-label {
            padding: 20px 30px 8px;
            font-size: 9px;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
        }

        .sidebar-footer {
            padding: 20px 30px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .logout {
            font-size: 10px;
            letter-spacing: 2px;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            text-decoration: none;
            transition: 0.3s;
        }

        .logout:hover { color: #b89a6a; }

        .main { margin-left: 240px; flex: 1; padding: 40px; }

        .page-header {
            margin-bottom: 36px;
        }

        .page-header h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            font-weight: 300;
            letter-spacing: 2px;
        }

        .page-header p {
            font-size: 12px;
            color: #7a6858;
            margin-top: 4px;
            letter-spacing: 1px;
        }

        .section {
            background: white;
            border: 1px solid #f2ead8;
            padding: 28px;
            box-shadow: 0 4px 20px rgba(42,31,23,0.05);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            text-align: left;
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #b89a6a;
            padding: 10px 12px;
            border-bottom: 1px solid #f2ead8;
        }

        td {
            padding: 14px 12px;
            border-bottom: 1px solid #faf6f1;
            color: #2a1f17;
            vertical-align: middle;
        }

        tr:last-child td { border-bottom: none; }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            font-size: 9px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            border-radius: 20px;
        }

        .badge-emitida { background: #fef3cd; color: #856404; }
        .badge-enviada { background: #cfe2ff; color: #084298; }
        .badge-pagada { background: #d1e7dd; color: #0a5236; }

        .btn {
            padding: 6px 14px;
            font-family: 'Jost', sans-serif;
            font-size: 9px;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-pdf {
            background: transparent;
            border: 1px solid #b89a6a;
            color: #b89a6a;
        }

        .btn-pdf:hover { background: #b89a6a; color: white; }

        .empty {
            text-align: center;
            color: #7a6858;
            padding: 32px;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <h1>Botaniq</h1>
            <span>Admin Panel</span>
        </div>
        <nav class="sidebar-menu">
            <div class="menu-label">Principal</div>
            <a href="/Admin/Dashboard" class="menu-item">Dashboard</a>
            <div class="menu-label">Gestión</div>
            <a href="/Admin/Productos" class="menu-item">Productos</a>
            <a href="/Admin/Usuarios" class="menu-item">Usuarios</a>
            <a href="/Admin/Pedidos" class="menu-item">Pedidos</a>
            <a href="/Admin/Facturas" class="menu-item active">Facturas</a>
            <a href="/Admin/Comentarios" class="menu-item">Comentarios</a>
        </nav>
        <div class="sidebar-footer">
            <a href="/Account/Login" class="logout">Cerrar sesión</a>
        </div>
    </aside>

    <main class="main">
        <div class="page-header">
            <h2>Facturas</h2>
            <p>Historial de facturas de Botaniq Bake</p>
        </div>

        <div class="section">
            <table>
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Cliente</th>
                        <th>Fecha Emisión</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="empty">No hay facturas registradas</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

</body>
</html>